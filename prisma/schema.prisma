// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  passwordHash String
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  transactions Transaction[]
  households   HouseholdMember[]
  uploads      Upload[]
  rules        CategorizationRule[]
  classifications Classification[]

  @@map("users")
}

model Household {
  id        String     @id @default(cuid())
  name      String
  createdBy String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  members      HouseholdMember[]
  transactions Transaction[]
  uploads      Upload[]
  rules        CategorizationRule[]
  classifications Classification[]

  @@map("households")
}

model HouseholdMember {
  id          String   @id @default(cuid())
  householdId String
  userId      String
  role        String   @default("member") // "admin" or "member"
  joinedAt    DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@map("household_members")
}

model Transaction {
  id                String    @id @default(cuid())
  userId            String?
  householdId       String?
  date              DateTime
  amount            Float
  merchant          String
  description       String?
  category          String?
  classification    String?   // "fixed", "variable", "savings_debt", or "income"
  sourceType        String    // "bank", "bit", "paypal", "google_pay", etc.
  linkedToId        String?   // Link to the duplicate/merged transaction
  isDuplicate       Boolean   @default(false)
  duplicateOfId     String?   // FK to original transaction if this is a duplicate
  uploadId          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  household Household?      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  upload    Upload?         @relation(fields: [uploadId], references: [id])
  linkedTransaction Transaction? @relation("LinkedTransactions", fields: [linkedToId], references: [id])
  links     Transaction[]   @relation("LinkedTransactions")

  @@index([userId])
  @@index([householdId])
  @@index([date])
  @@index([sourceType])
  @@map("transactions")
}

model Upload {
  id            String   @id @default(cuid())
  userId        String?
  householdId   String?
  fileName      String
  uploadDate    DateTime @default(now())
  transactionCount Int
  sourceType    String   // "bank", "bit", "paypal", etc.

  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  household    Household?     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("uploads")
}

model CategorizationRule {
  id           String  @id @default(cuid())
  householdId  String?
  userId       String?
  merchantPattern String // regex pattern
  targetCategory String
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  household Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("categorization_rules")
}

model Classification {
  id           String  @id @default(cuid())
  householdId  String?
  userId       String?
  category     String
  type         String  // "fixed", "variable", "savings_debt", or "income"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  household Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, category])
  @@map("classifications")
}
